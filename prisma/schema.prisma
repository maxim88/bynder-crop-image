generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model BynderWebhookEvent {
  id        String   @id @default(cuid())
  topic     String
  assetId   String?
  payload   Json
  createdAt DateTime @default(now())

  @@index([topic])
  @@index([assetId])
}
